# DARIS 环境配置模板
# 复制此文件为.env 并填写实际值

# ==================== 大模型 API 配置 ====================

# 阿里云通义千问（主要使用）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# Anthropic API（备用）
ANTHROPIC_API_KEY=your-api-key-here

# DeepSeek API（备用）
DEEPSEEK_API_KEY=your-api-key-here

# ==================== 学术 API 配置 ====================

# Semantic Scholar API
SEMANTIC_SCHOLAR_API_KEY=your-api-key-here

# arXiv API
ARXIV_API_KEY=your-api-key-here

# ==================== Zotero 配置 ====================

ZOTERO_API_KEY=your-zotero-api-key-here
ZOTERO_USER_ID=your-zotero-user-id-here
ZOTERO_LIBRARY_TYPE=user
ZOTERO_COLLECTION_NAME=DARIS

# ==================== 阿里云服务器配置 ====================

ALIYUN_SERVER_IP=47.100.98.160
ALIYUN_SERVER_PORT=22
ALIYUN_SERVER_USER=root
ALIYUN_SERVER_PASSWORD=your-server-password-here
ALIYUN_SERVER_WORK_DIR=/home/root/DARIS/

# ==================== 钉钉机器人配置 ====================

DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=your-dingtalk-sign-secret

# ==================== 工作区锚点配置 ====================

# 当前激活工作区由 .current_workspace 控制，默认值为 workspace_default
# 工作区目录结构：workspaces/workspace_xxx/
# 只读公共路径：core/

# ==================== Git 配置 ====================

GIT_REPO_URL=https://github.com/your-username/DARIS
GIT_USER_NAME=your-git-username
GIT_USER_EMAIL=your-git-email@example.com

# ==================== 其他配置 ====================

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 是否启用自动回滚
AUTO_ROLLBACK_ENABLED=true

# 最大迭代轮次
MAX_ITERATIONS=50

# 单轮训练最大时长（分钟）
MAX_TRAIN_DURATION=30